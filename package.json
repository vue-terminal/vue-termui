{
  "name": "vue-termui",
  "version": "0.2.0",
  "description": "Build terminal apps with Vue 3",
  "keywords": [
    "vue",
    "terminal",
    "tui",
    "renderer",
    "cli",
    "opentui"
  ],
  "homepage": "https://github.com/vue-terminal/vue-termui",
  "bugs": {
    "url": "https://github.com/vue-terminal/vue-termui/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Eduardo San Martin Morote",
    "email": "posva13@gmail.com"
  },
  "repository": "vue-terminal/vue-termui",
  "funding": "https://github.com/sponsors/posva",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./vite": "./dist/vite.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "NODE_OPTIONS='--experimental-ffi --disable-warning=ExperimentalWarning' vitest --ui",
    "docs": "pnpm --filter @vue-termui/docs dev",
    "docs:build": "pnpm --filter @vue-termui/docs build",
    "play": "pnpm --filter playground dev",
    "test": "pnpm run lint && pnpm run fmt --check && pnpm run build && pnpm run test:cov && pnpm run test:types",
    "test:cov": "NODE_OPTIONS='--experimental-ffi --disable-warning=ExperimentalWarning' vitest run --coverage",
    "test:types": "tsc --build ./tsconfig.json",
    "lint": "oxlint ${CI:+--deny-warnings} .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt",
    "prepare": "simple-git-hooks",
    "release": "node scripts/release.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1",
    "@vue/runtime-core": "^3.5.32"
  },
  "devDependencies": {
    "@posva/prompts": "^2.4.4",
    "@size-limit/esbuild-why": "^12.1.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.0.0",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@vue/compiler-dom": "^3.5.32",
    "@vue/runtime-dom": "^3.5.32",
    "@vue/test-utils": "^2.4.6",
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-angular": "^8.3.1",
    "happy-dom": "^20.8.9",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-plugin-posva": "^0.0.2",
    "semver": "^7.8.5",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.3.6"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "vite": "^8.0.0",
    "vue": "^3.5.17"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "node scripts/verifyCommit.js"
  },
  "lint-staged": {
    "*": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint --no-error-on-unmatched-pattern --fix"
    ]
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=26.3.0"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
  "volta": {
    "node": "26.4.0"
  }
}
